<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FAF4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prediction_result"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:gravity="center" />

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/imgResult"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/card_white"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_disease" />

        <!-- WARNING CARD -->
        <LinearLayout
            android:id="@+id/warningCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#FFF3CD"
            android:padding="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠ Warning"
                android:textStyle="bold"
                android:textColor="#856404"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#856404"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- FINAL DISEASE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_ripple"
            android:padding="16dp"
            android:elevation="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detected_disease"
                android:textColor="#777777"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDisease"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disease Name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- CONFIDENCE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_ripple"
            android:padding="16dp"
            android:elevation="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confidence"
                android:textColor="#777777"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- AGREEMENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_ripple"
            android:padding="16dp"
            android:elevation="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Model Agreement"
                android:textColor="#777777"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtAgreement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 / 4 models agree"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- MODEL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_ripple"
            android:padding="16dp"
            android:elevation="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/model"
                android:textColor="#777777"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtModel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stacking Ensemble"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- INFERENCE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/card_ripple"
            android:padding="16dp"
            android:elevation="2dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inference_time"
                android:textColor="#777777"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtInferenceTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 sec"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- INDIVIDUAL MODEL RESULTS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_ripple"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Individual Model Predictions"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#1B5E20"/>

            <TextView
                android:id="@+id/txtResNet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="ResNet50: Brown Spot (95%)"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/txtVGG16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="VGG16: Brown Spot (93%)"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/txtXception"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Xception: Brown Spot (96%)"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/txtMobileNet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="MobileNetV2: Brown Spot (91%)"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnAdvice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="22dp"
            android:text="@string/get_ai_advice"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>

</ScrollView>